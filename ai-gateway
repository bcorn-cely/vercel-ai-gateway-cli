#!/usr/bin/env python3
"""
ai-gateway — terminal CLI for the Vercel AI Gateway public REST endpoints.

Endpoints (no auth required):
  GET https://ai-gateway.vercel.sh/v1/models
  GET https://ai-gateway.vercel.sh/v1/models/{creator}/{model}/endpoints

Docs: https://vercel.com/docs/ai-gateway/models-and-providers
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import shutil
import sys
import urllib.error
import urllib.parse
import urllib.request
from typing import Any

BASE_URL = "https://ai-gateway.vercel.sh/v1"
USER_AGENT = "vercel-ai-gateway-cli/0.1 (+https://vercel.com/docs/ai-gateway)"


# ---------- formatting ----------

def _use_color() -> bool:
    if os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty()


def c(text: str, code: str) -> str:
    if not _use_color():
        return text
    return f"\033[{code}m{text}\033[0m"


def bold(t: str) -> str: return c(t, "1")
def dim(t: str) -> str: return c(t, "2")
def red(t: str) -> str: return c(t, "31")
def green(t: str) -> str: return c(t, "32")
def yellow(t: str) -> str: return c(t, "33")
def blue(t: str) -> str: return c(t, "34")
def cyan(t: str) -> str: return c(t, "36")


def term_width(default: int = 100) -> int:
    try:
        return shutil.get_terminal_size((default, 24)).columns
    except Exception:
        return default


def truncate(s: str, n: int) -> str:
    s = s or ""
    if len(s) <= n:
        return s
    return s[: max(0, n - 1)] + "…"


def print_table(rows: list[list[str]], headers: list[str]) -> None:
    if not rows:
        print(dim("(no rows)"))
        return
    widths = [len(h) for h in headers]
    for r in rows:
        for i, cell in enumerate(r):
            widths[i] = max(widths[i], len(str(cell)))
    max_w = term_width() - (3 * (len(headers) - 1)) - 2
    total = sum(widths)
    if total > max_w:
        # shrink the longest column(s) proportionally
        scale = max_w / total
        widths = [max(8, int(w * scale)) for w in widths]

    def fmt_row(cells: list[str], header: bool = False) -> str:
        parts = []
        for i, cell in enumerate(cells):
            cell = truncate(str(cell), widths[i])
            cell = cell.ljust(widths[i])
            parts.append(bold(cell) if header else cell)
        return "  ".join(parts)

    print(fmt_row(headers, header=True))
    print(dim("  ".join("-" * w for w in widths)))
    for r in rows:
        print(fmt_row(r))


# ---------- HTTP ----------

def fetch_json(path: str, timeout: float = 30.0) -> dict[str, Any]:
    url = f"{BASE_URL}{path}"
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT, "Accept": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8", "replace")
        except Exception:
            pass
        raise SystemExit(red(f"HTTP {e.code} from {url}\n{body}"))
    except urllib.error.URLError as e:
        raise SystemExit(red(f"Network error reaching {url}: {e.reason}"))
    except json.JSONDecodeError as e:
        raise SystemExit(red(f"Invalid JSON from {url}: {e}"))


def list_models() -> list[dict[str, Any]]:
    data = fetch_json("/models")
    return data.get("data", [])


def model_endpoints(model_id: str) -> dict[str, Any]:
    if "/" not in model_id:
        raise SystemExit(red(f"Model ID must be 'creator/model', got: {model_id!r}"))
    creator, model = model_id.split("/", 1)
    encoded = f"/{urllib.parse.quote(creator)}/{urllib.parse.quote(model)}"
    return fetch_json(f"/models{encoded}/endpoints").get("data", {})


# ---------- helpers ----------

def fmt_price(p: Any) -> str:
    if p is None or p == "":
        return "-"
    try:
        v = float(p)
    except Exception:
        return str(p)
    if v == 0:
        return "free"
    # render per-million-token if it's a per-token rate (< 1)
    if v < 1:
        return f"${v * 1_000_000:.2f}/M"
    return f"${v}"


def fmt_int(n: Any) -> str:
    if n is None:
        return "-"
    try:
        return f"{int(n):,}"
    except Exception:
        return str(n)


def match_search(m: dict[str, Any], q: str) -> bool:
    q = q.lower()
    blob = " ".join(
        str(m.get(k, "")) for k in ("id", "name", "description", "owned_by", "type")
    )
    tags = " ".join(m.get("tags") or [])
    return q in (blob + " " + tags).lower()


# ---------- fuzzy resolution ----------

_NORM_RE = re.compile(r"[\s\-_/]+")  # keep '.' inside tokens so "5.5" stays whole


def _norm(s: str) -> str:
    return _NORM_RE.sub(" ", (s or "").lower()).strip()


def fuzzy_score(m: dict[str, Any], query: str) -> int:
    q = query.strip()
    if not q:
        return 0
    if (m.get("id") or "").lower() == q.lower():
        return 10_000
    q_tokens = _norm(q).split()
    if not q_tokens:
        return 0
    id_n = _norm(m.get("id") or "")
    name_n = _norm(m.get("name") or "")
    desc_n = _norm(m.get("description") or "")
    strong = f"{id_n} {name_n}"
    # Hard requirement: every query token must appear in id or name.
    # Description is only used for scoring tiebreakers, never as a gate
    # (otherwise "claude opus" would surface models whose docs mention Opus).
    if not all(t in strong for t in q_tokens):
        return 0
    score = 0
    if all(t in id_n for t in q_tokens):
        score += 80
    if all(t in name_n for t in q_tokens):
        score += 50
    for t in q_tokens:
        if t in id_n:
            score += 10
        elif t in name_n:
            score += 5
        elif t in desc_n:
            score += 1
    # prefer shorter ids (less specific suffixes) when score ties
    score -= len(m.get("id") or "") // 20
    return score


def fuzzy_search(models: list[dict[str, Any]], query: str, limit: int = 10) -> list[dict[str, Any]]:
    scored = [(fuzzy_score(m, query), m) for m in models]
    scored = [pair for pair in scored if pair[0] > 0]
    scored.sort(key=lambda pair: (-pair[0], (pair[1].get("id") or "").lower()))
    return [m for _, m in scored[:limit]]


def _is_interactive() -> bool:
    try:
        return sys.stdin.isatty() and sys.stdout.isatty()
    except Exception:
        return False


def pick_one(candidates: list[dict[str, Any]], query: str) -> dict[str, Any] | None:
    print()
    print(bold(f"{len(candidates)} matches for {query!r}:"))
    for i, m in enumerate(candidates, 1):
        name = m.get("name") or ""
        typ = m.get("type") or ""
        print(f"  {yellow(str(i).rjust(2))}  {m.get('id')}  {dim(f'({typ}) {name}')}")
    print()
    try:
        raw = input(cyan("Pick a number (or blank to cancel): ")).strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None
    if not raw:
        return None
    try:
        idx = int(raw)
    except ValueError:
        print(red("Not a number."))
        return None
    if not (1 <= idx <= len(candidates)):
        print(red("Out of range."))
        return None
    return candidates[idx - 1]


def resolve_model_id(query: str, prefer: str | None = None) -> str:
    """Return a concrete creator/model id, fuzzy-resolving query if needed.

    prefer:
      None       interactive picker when ambiguous and TTY; else error
      'first'    silently take the highest-scoring match
      'pick'     always show picker (even if 1 match)
    """
    models = list_models()
    by_id = {m.get("id"): m for m in models if m.get("id")}

    # exact match short-circuit
    if query in by_id and prefer != "pick":
        return query

    candidates = fuzzy_search(models, query, limit=10)
    if not candidates:
        raise SystemExit(red(f"No models match {query!r}. Try `ai-gateway models --search '<term>'` to browse."))

    if prefer == "first":
        picked = candidates[0]
        print(dim(f"→ Using {picked.get('id')} (highest-scoring match for {query!r})"))
        return picked["id"]

    if len(candidates) == 1 and prefer != "pick":
        picked = candidates[0]
        print(dim(f"→ Resolved {query!r} → {picked.get('id')}"))
        return picked["id"]

    if _is_interactive():
        chosen = pick_one(candidates, query)
        if not chosen:
            raise SystemExit(yellow("Cancelled."))
        return chosen["id"]

    # non-interactive: list and exit
    print(red(f"Ambiguous: {len(candidates)} models match {query!r}. Be more specific or use --first."), file=sys.stderr)
    for m in candidates:
        print(f"  {m.get('id')}  ({m.get('type')}) {m.get('name')}", file=sys.stderr)
    raise SystemExit(1)


# ---------- schema introspection ----------

def _type_name(v: Any) -> str:
    if v is None:
        return "null"
    if isinstance(v, bool):
        return "boolean"
    if isinstance(v, int):
        return "integer"
    if isinstance(v, float):
        return "number"
    if isinstance(v, str):
        return "string"
    if isinstance(v, list):
        return "array"
    if isinstance(v, dict):
        return "object"
    return type(v).__name__


def _sample(v: Any, n: int = 60) -> str:
    s = json.dumps(v, ensure_ascii=False)
    if len(s) <= n:
        return s
    return s[: n - 1] + "…"


def describe_schema(value: Any, prefix: str = "") -> list[tuple[str, str, str]]:
    """Walk JSON value and produce [(path, type, example)] rows."""
    rows: list[tuple[str, str, str]] = []

    def walk(v: Any, path: str, suppress_header: bool = False) -> None:
        if isinstance(v, dict):
            if path and not suppress_header:
                rows.append((path, "object", ""))
            for k, sub in v.items():
                child = f"{path}.{k}" if path else k
                walk(sub, child)
        elif isinstance(v, list):
            if not v:
                rows.append((f"{path}[]", "array (empty)", "[]"))
                return
            child_type = _type_name(v[0])
            label = f"{path}[]"
            if isinstance(v[0], dict):
                rows.append((label, f"array of object (len={len(v)})", ""))
                walk(v[0], label, suppress_header=True)
            else:
                rows.append((label, f"array of {child_type}", _sample(v[:3])))
        else:
            rows.append((path, _type_name(v), _sample(v)))

    walk(value, prefix)
    return rows


def print_schema(label: str, raw: Any, full_endpoint: str, sample_note: str | None = None) -> None:
    rows = describe_schema(raw)
    print()
    print(bold(label))
    print(dim(full_endpoint))
    if sample_note:
        print(dim(sample_note))
    print()
    # widths
    path_w = max((len(r[0]) for r in rows), default=4)
    type_w = max((len(r[1]) for r in rows), default=4)
    path_w = min(path_w, 60)
    type_w = min(type_w, 28)
    print(bold(f"{'path'.ljust(path_w)}  {'type'.ljust(type_w)}  example"))
    print(dim("-" * path_w + "  " + "-" * type_w + "  " + "-" * 20))
    for path, tname, ex in rows:
        p = truncate(path, path_w).ljust(path_w)
        t = truncate(tname, type_w).ljust(type_w)
        print(f"{p}  {t}  {ex}")
    print()


# ---------- commands ----------

def cmd_models(args: argparse.Namespace) -> int:
    models = list_models()

    if args.type:
        models = [m for m in models if m.get("type") == args.type]
    if args.provider:
        p = args.provider.lower()
        models = [m for m in models if str(m.get("owned_by", "")).lower() == p]
    if args.tag:
        t = args.tag.lower()
        models = [m for m in models if t in [str(x).lower() for x in (m.get("tags") or [])]]
    if args.search:
        models = [m for m in models if match_search(m, args.search)]

    sort_key = args.sort
    def sortkey(m: dict[str, Any]) -> Any:
        if sort_key == "name":
            return (m.get("name") or m.get("id") or "").lower()
        if sort_key == "context":
            return -int(m.get("context_window") or 0)
        if sort_key == "input_price":
            return float((m.get("pricing") or {}).get("input") or 0)
        if sort_key == "output_price":
            return float((m.get("pricing") or {}).get("output") or 0)
        return (m.get("id") or "").lower()
    models.sort(key=sortkey)

    if args.json:
        json.dump(models, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return 0

    if not models:
        print(yellow("No models match those filters."))
        return 0

    rows = []
    for m in models:
        pricing = m.get("pricing") or {}
        rows.append([
            m.get("id", ""),
            m.get("type", ""),
            fmt_int(m.get("context_window")),
            fmt_int(m.get("max_tokens")),
            fmt_price(pricing.get("input")),
            fmt_price(pricing.get("output")),
            ",".join(m.get("tags") or []),
        ])
    print(bold(f"\n{len(models)} model(s)\n"))
    print_table(
        rows,
        headers=["id", "type", "ctx", "max_out", "in $/M", "out $/M", "tags"],
    )
    print()
    return 0


def cmd_providers(args: argparse.Namespace) -> int:
    prefer = "first" if getattr(args, "first", False) else ("pick" if getattr(args, "pick", False) else None)
    model_id = resolve_model_id(args.model, prefer=prefer)
    data = model_endpoints(model_id)
    if args.json:
        json.dump(data, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return 0

    print()
    print(bold(data.get("name") or args.model))
    print(dim(data.get("id") or ""))
    desc = data.get("description")
    if desc:
        print()
        print(desc)

    arch = data.get("architecture") or {}
    print()
    print(f"{bold('Modality:')}        {arch.get('modality', '-')}")
    print(f"{bold('Input modes:')}     {', '.join(arch.get('input_modalities') or []) or '-'}")
    print(f"{bold('Output modes:')}    {', '.join(arch.get('output_modalities') or []) or '-'}")

    endpoints = data.get("endpoints") or []
    print()
    print(bold(f"{len(endpoints)} provider endpoint(s):"))
    print()

    rows = []
    for e in endpoints:
        pricing = e.get("pricing") or {}
        rows.append([
            e.get("provider_name") or "-",
            fmt_int(e.get("context_length")),
            fmt_int(e.get("max_completion_tokens")),
            fmt_price(pricing.get("prompt")),
            fmt_price(pricing.get("completion")),
            fmt_price(pricing.get("input_cache_read")),
            "yes" if e.get("supports_implicit_caching") else "no",
            "active" if e.get("status") == 0 else f"status={e.get('status')}",
        ])
    print_table(
        rows,
        headers=["provider", "ctx", "max_out", "prompt $/M", "completion $/M", "cache_read $/M", "implicit_cache", "status"],
    )

    if args.params:
        print()
        print(bold("Supported parameters per provider:"))
        for e in endpoints:
            print(f"  {cyan(e.get('provider_name') or '-')}: {', '.join(e.get('supported_parameters') or [])}")
    print()
    return 0


def cmd_info(args: argparse.Namespace) -> int:
    models = list_models()
    if args.json:
        summary = build_summary(models)
        json.dump(summary, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return 0

    summary = build_summary(models)
    print()
    print(bold("Vercel AI Gateway — summary"))
    print(dim(BASE_URL))
    print()
    print(f"{bold('Total models:')}     {summary['total']}")
    print()
    print(bold("By type:"))
    for t, count in summary["by_type"].items():
        print(f"  {t:<12} {count}")
    print()
    print(bold("Top owners (by model count):"))
    for owner, count in summary["by_owner"][:15]:
        print(f"  {owner:<24} {count}")
    print()
    print(bold("Top tags:"))
    for tag, count in summary["by_tag"][:15]:
        print(f"  {tag:<20} {count}")
    print()
    print(bold("Pricing — language models ($/M tokens):"))
    lp = summary["language_pricing"]
    if lp["count"]:
        print(f"  input:   min {fmt_price(lp['input_min'])}   median {fmt_price(lp['input_med'])}   max {fmt_price(lp['input_max'])}")
        print(f"  output:  min {fmt_price(lp['output_min'])}  median {fmt_price(lp['output_med'])}  max {fmt_price(lp['output_max'])}")
    else:
        print(dim("  (no language models found)"))
    print()
    return 0


def build_summary(models: list[dict[str, Any]]) -> dict[str, Any]:
    by_type: dict[str, int] = {}
    by_owner: dict[str, int] = {}
    by_tag: dict[str, int] = {}
    lang_in: list[float] = []
    lang_out: list[float] = []

    for m in models:
        t = m.get("type") or "unknown"
        by_type[t] = by_type.get(t, 0) + 1
        o = m.get("owned_by") or "unknown"
        by_owner[o] = by_owner.get(o, 0) + 1
        for tag in (m.get("tags") or []):
            by_tag[tag] = by_tag.get(tag, 0) + 1
        if t == "language":
            p = m.get("pricing") or {}
            try:
                if p.get("input") is not None:
                    lang_in.append(float(p["input"]))
            except Exception:
                pass
            try:
                if p.get("output") is not None:
                    lang_out.append(float(p["output"]))
            except Exception:
                pass

    def median(xs: list[float]) -> float:
        if not xs:
            return 0.0
        s = sorted(xs)
        n = len(s)
        mid = n // 2
        return s[mid] if n % 2 else (s[mid - 1] + s[mid]) / 2

    return {
        "total": len(models),
        "by_type": dict(sorted(by_type.items(), key=lambda kv: -kv[1])),
        "by_owner": sorted(by_owner.items(), key=lambda kv: -kv[1]),
        "by_tag": sorted(by_tag.items(), key=lambda kv: -kv[1]),
        "language_pricing": {
            "count": len(lang_in),
            "input_min": min(lang_in) if lang_in else None,
            "input_max": max(lang_in) if lang_in else None,
            "input_med": median(lang_in),
            "output_min": min(lang_out) if lang_out else None,
            "output_max": max(lang_out) if lang_out else None,
            "output_med": median(lang_out),
        },
    }


SCHEMA_SAMPLE_MODELS = [
    "anthropic/claude-opus-4.7",
    "openai/gpt-5.5",
    "google/gemini-3.1-pro-preview",
]


def cmd_schema(args: argparse.Namespace) -> int:
    endpoint = args.endpoint

    if endpoint == "models":
        raw = fetch_json("/models")
        if args.raw:
            json.dump({"object": raw.get("object"), "data": (raw.get("data") or [])[:1]}, sys.stdout, indent=2)
            sys.stdout.write("\n")
            return 0
        # narrow to representative shape: top-level + first data entry
        sample = {
            "object": raw.get("object"),
            "data": [(raw.get("data") or [{}])[0]],
        }
        print_schema(
            "GET /v1/models  —  list all models",
            sample,
            full_endpoint=f"{BASE_URL}/models",
            sample_note=f"Sample drawn from data[0] (id: {(raw.get('data') or [{}])[0].get('id', '?')}). All data[] entries share this shape.",
        )
        return 0

    if endpoint == "providers":
        model_id = args.model
        last_err: SystemExit | None = None
        if model_id is None:
            for candidate in SCHEMA_SAMPLE_MODELS:
                try:
                    data = fetch_json(f"/models/{candidate}/endpoints").get("data", {})
                    model_id = candidate
                    break
                except SystemExit as e:
                    last_err = e
                    continue
            else:
                if last_err:
                    raise last_err
                raise SystemExit(red("Could not fetch a sample provider response."))
        else:
            data = model_endpoints(resolve_model_id(model_id))

        if args.raw:
            # collapse endpoints[] to the first entry for readability
            shown = dict(data)
            eps = shown.get("endpoints") or []
            if eps:
                shown["endpoints"] = [eps[0]]
            json.dump({"data": shown}, sys.stdout, indent=2)
            sys.stdout.write("\n")
            return 0

        print_schema(
            "GET /v1/models/{creator}/{model}/endpoints  —  provider endpoints for a model",
            {"data": data},
            full_endpoint=f"{BASE_URL}/models/{model_id}/endpoints",
            sample_note=f"Sample drawn from {model_id}. Other models share this shape; some pricing fields are optional.",
        )
        return 0

    raise SystemExit(red(f"Unknown schema endpoint: {endpoint}"))


def cmd_repl(args: argparse.Namespace) -> int:
    print(bold("ai-gateway interactive shell"))
    print(dim("Commands: models [filters], providers <id>, info, help, quit"))
    print(dim("Filters: --type {language,embedding,reranking,image,video}  --provider <name>  --tag <name>  --search <q>"))
    print()
    parser = build_parser()
    while True:
        try:
            line = input(cyan("ai-gateway> ")).strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return 0
        if not line:
            continue
        if line in ("quit", "exit", "q"):
            return 0
        if line in ("help", "?"):
            parser.print_help()
            continue
        try:
            argv = shlex.split(line)
        except ValueError as e:
            print(red(f"Parse error: {e}"))
            continue
        try:
            ns = parser.parse_args(argv)
        except SystemExit:
            continue
        if not getattr(ns, "func", None):
            continue
        try:
            ns.func(ns)
        except SystemExit as e:
            print(red(str(e)))
        except Exception as e:
            print(red(f"Error: {e}"))


# ---------- parser ----------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="ai-gateway",
        description="Query the Vercel AI Gateway public REST endpoints (no auth required).",
    )
    sub = p.add_subparsers(dest="command")

    pm = sub.add_parser("models", help="List/filter available models")
    pm.add_argument("--type", choices=["language", "embedding", "reranking", "image", "video"])
    pm.add_argument("--provider", help="Filter by owned_by (e.g. openai, anthropic, google)")
    pm.add_argument("--tag", help="Filter by tag (e.g. reasoning, tool-use, vision)")
    pm.add_argument("--search", help="Substring match across id, name, description, owner, tags")
    pm.add_argument("--sort", choices=["id", "name", "context", "input_price", "output_price"], default="id")
    pm.add_argument("--json", action="store_true", help="Output raw JSON")
    pm.set_defaults(func=cmd_models)

    pp = sub.add_parser("providers", help="List provider endpoints + pricing for a model (accepts partial names)")
    pp.add_argument("model", help="Model id or partial name (e.g. 'claude opus', 'gpt-5.5', 'gemini 3 pro')")
    pp.add_argument("--params", action="store_true", help="Also print supported_parameters per provider")
    pp.add_argument("--first", action="store_true", help="On ambiguous match, take the highest-scoring result")
    pp.add_argument("--pick", action="store_true", help="Always show interactive picker, even for a single match")
    pp.add_argument("--json", action="store_true", help="Output raw JSON")
    pp.set_defaults(func=cmd_providers)

    pi = sub.add_parser("info", help="High-level summary of the gateway (counts, owners, tags, pricing)")
    pi.add_argument("--json", action="store_true", help="Output raw JSON")
    pi.set_defaults(func=cmd_info)

    ps = sub.add_parser("schema", help="Describe the response shape of a gateway endpoint (introspected from live data)")
    ps.add_argument("endpoint", choices=["models", "providers"], help="Which endpoint to describe")
    ps.add_argument("--model", help="(providers only) Use a specific model as the sample. Accepts partial name.")
    ps.add_argument("--raw", action="store_true", help="Print a pretty-printed sample JSON instead of the annotated walk")
    ps.set_defaults(func=cmd_schema)

    pr = sub.add_parser("repl", help="Interactive shell")
    pr.set_defaults(func=cmd_repl)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    if argv is None:
        argv = sys.argv[1:]
    if not argv:
        return cmd_repl(argparse.Namespace())
    args = parser.parse_args(argv)
    if not getattr(args, "func", None):
        parser.print_help()
        return 2
    return args.func(args) or 0


if __name__ == "__main__":
    sys.exit(main())
